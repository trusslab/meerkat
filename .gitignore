# ignore the actual compilers
compilers/gcc-[0-9]*/
compilers/clang-[0-9]*/
compilers/failed*
compilers/tars/
compilers/test.c

# ignore compiled files
helpers/diffdate
build/
bin/

# execs in tools
tools/findmerge

tools/*.txt
tools/*.log

# ignore the compiled images
image/wheezy/ssh/
image/wheezy/wheezy/
image/wheezy/wheezy.img
image/stretch/chroot/
image/stretch/stretch.img
image/stretch/stretch.id_rsa
image/stretch/stretch.id_rsa.pub

# ignore some odd files
interesting_results/
old_logs/
archive/

# ignore the data files in parse
parse/*.csv
parse/*.txt

# ignore some stuff in the templates directory
redo/

# ignore working directories
wd-inspector-[0-9]*/
wd-bisector-[0-9]*/

# ignore local-only files
parameters/config.cfg
tmp*

# don't re-distribute syzkaller code
syzcache/

# ignore files from C++ impl
.vscode/
syzInspector
syzInspector-debug
